# Jira Module environment template
# Copy to .env and fill with your real values.

# Server
PORT=3001
SSL_KEY_PATH=
SSL_CERT_PATH=

# Jira connectivity
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_WEBHOOK_SECRET=your_webhook_secret
JIRA_ENRICH_FROM_API=false

# GitHub worker (optional in this module)
GITHUB_REPO_URL=
GITHUB_TOKEN=
WORKSPACE_DIR=
GITHUB_BASE_BRANCH=main

# LLM/plan worker (optional in this module)
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Test command (optional)
TEST_COMMAND=npm test

# Webhook capture
JIRA_CAPTURE_PAYLOADS=true
JIRA_CAPTURE_DIR=samples/webhooks/captured
JIRA_CAPTURE_RESPONSES=true
JIRA_RESPONSE_DIR=samples/webhooks/responses

# Trigger rules
JIRA_TRIGGER_ON_CREATE=true
JIRA_TRIGGER_STATUSES=Ready for Development
JIRA_TRIGGER_LABELS=auto-dev

# Validation rules
JIRA_VALIDATION_ENABLED=true
JIRA_REQUIRE_REPOSITORY_REFERENCE=true
JIRA_REQUIRE_DESCRIPTION=true
JIRA_MIN_DESCRIPTION_LENGTH=40
JIRA_REQUIRE_LABELS=true
JIRA_ALLOWED_LABELS=
JIRA_REQUIRE_ACCEPTANCE_CRITERIA=false
JIRA_MIN_ACCEPTANCE_CRITERIA_LENGTH=20
